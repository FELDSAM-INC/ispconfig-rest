# ISPConfig REST API — dedicated Apache vhost (what the installer generates on
# an Apache host with php-fpm). Talks to a dedicated php-fpm pool over a socket
# and reuses the ISPConfig panel SSL certificate. Standalone — it does NOT touch
# ISPConfig's own interface (8080) / apps (8081) vhosts.
#
# Needs: a2enmod ssl rewrite headers proxy proxy_fcgi setenvif
# Pair with the php-fpm pool in deploy/php-fpm-pool.conf.example.

Listen 8090
<VirtualHost _default_:8090>
    ServerName server.example.com
    DocumentRoot /opt/ispconfig-rest/public

    SSLEngine On
    SSLProtocol All -SSLv3 -TLSv1 -TLSv1.1
    SSLHonorCipherOrder On
    SSLCertificateFile /usr/local/ispconfig/interface/ssl/ispserver.crt
    SSLCertificateKeyFile /usr/local/ispconfig/interface/ssl/ispserver.key
    # Include only if the bundle exists:
    SSLCACertificateFile /usr/local/ispconfig/interface/ssl/ispserver.bundle

    <FilesMatch \.php$>
        SetHandler "proxy:unix:/run/ispconfig-rest.sock|fcgi://localhost"
    </FilesMatch>

    <Directory /opt/ispconfig-rest/public>
        Options FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog  ${APACHE_LOG_DIR}/ispconfig-rest-error.log
    CustomLog ${APACHE_LOG_DIR}/ispconfig-rest-access.log combined
</VirtualHost>
