# ISPConfig REST API — nginx reverse proxy snippet
#
# The API runs as a local systemd service (default 127.0.0.1:8090). Front it
# with your existing web server. Add this inside an HTTPS server block — ideally
# the ISPConfig control-panel vhost or a dedicated api.example.com vhost.

location /api/ {
    proxy_pass         http://127.0.0.1:8090;
    proxy_http_version 1.1;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Real-IP         $remote_addr;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
}
