# ISPConfig REST API — Apache reverse proxy snippet
#
# The API runs as a local systemd service (default 127.0.0.1:8090). Front it
# with your existing web server. Requires: a2enmod proxy proxy_http.
# Add this inside an HTTPS <VirtualHost> (e.g. the ISPConfig panel vhost).

ProxyPreserveHost On
ProxyPass        "/api/" "http://127.0.0.1:8090/api/"
ProxyPassReverse "/api/" "http://127.0.0.1:8090/api/"
RequestHeader set X-Forwarded-Proto "https"
