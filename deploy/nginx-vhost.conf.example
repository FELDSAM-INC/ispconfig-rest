# ISPConfig REST API — dedicated nginx vhost (what the installer generates on an
# nginx host). Serves the app via a dedicated php-fpm pool over a socket and
# reuses the ISPConfig panel SSL certificate. Standalone — it does NOT touch
# ISPConfig's own vhosts.
#
# Pair with the php-fpm pool in deploy/php-fpm-pool.conf.example.

server {
    listen 8090 ssl;
    server_name server.example.com;
    root /opt/ispconfig-rest/public;
    index index.php;

    ssl_certificate     /usr/local/ispconfig/interface/ssl/ispserver.crt;   # or ispserver.pem (full chain)
    ssl_certificate_key /usr/local/ispconfig/interface/ssl/ispserver.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / { try_files $uri $uri/ /index.php?$query_string; }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/ispconfig-rest.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param HTTPS on;
    }

    location ~ /\.(?!well-known).* { deny all; }
}
