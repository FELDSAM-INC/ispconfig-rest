# ISPConfig REST API — dedicated nginx vhost (what the installer generates for
# an nginx host). nginx terminates TLS with the ISPConfig panel certificate and
# proxies to the app's local service (a systemd unit running `artisan serve` on
# 127.0.0.1:8091). Place in /etc/nginx/sites-available/ and symlink into
# sites-enabled.
#
# Standalone vhost — it does NOT touch ISPConfig's own vhosts.

server {
    listen 8090 ssl;
    server_name server.example.com;

    ssl_certificate     /usr/local/ispconfig/interface/ssl/ispserver.crt;
    ssl_certificate_key /usr/local/ispconfig/interface/ssl/ispserver.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass         http://127.0.0.1:8091;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;
    }
}
