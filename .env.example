APP_NAME=ISPConfig-REST
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dbispconfig
DB_USERNAME=ispconfig
DB_PASSWORD=ispconfig

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ISPConfig API Settings
API_VERSION=1.0
API_PREFIX=api/v1
