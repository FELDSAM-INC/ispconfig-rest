APP_NAME="ISPConfig REST API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ISPConfig database (schema owned by ISPConfig — never migrated by this app)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dbispconfig
DB_USERNAME=ispconfig
DB_PASSWORD=ispconfig

SESSION_DRIVER=array
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local

MAIL_MAILER=log

# ISPConfig API settings
API_VERSION=1.0
# Dev-only key accepted in local/development/testing environments (acts as admin).
# Leave empty in production; mint real keys with: php artisan api:key:create
API_DEV_KEY=
